  "clues": {
    "across": [
      { "num": "一", "text": "位於屏東縣的一個鄉鎮，以檸檬生產及200多年歷史的三山國王廟聞名。" },
      { "num": "二", "text": "連接波斯灣與阿曼灣的水域，是運輸石油的咽喉要道，近期因國際局勢成為軍事焦點。" },
      { "num": "三", "text": "明末清初來華的德籍傳教士，對中國曆法貢獻卓著。" },
      { "num": "四", "text": "由統一企業推出的知名杯麵品牌。" },
      { "num": "五", "text": "世界上體型最大的鹿科動物，出沒於北半球溫帶至亞北極氣候的林間，雄性擁有扇平狀的大角。" },
      { "num": "六", "text": "成語，針對病症開方用藥；比喻針對問題的關鍵採取應對措施。" },
      { "num": "七", "text": "詩人李白名篇，描述四川地方交通艱險的歌辭。" },
      { "num": "八", "text": "中美混血滑雪運動員，在 2022 與 2026 冬季奧運表現出色。" },
      { "num": "九", "text": "經過自動化清洗、殺菌、風乾、檢查裂痕與分級等專業處理，去除污染後噴上保護油膜與編號的雞蛋。" },
      { "num": "十", "text": "位於中東，目前是世界第二大石油生產國及大型石油出口國之一，首都為利雅德。" }
    ],
    "down": [
      { "num": "1", "text": "現代用語，指在多種選項前猶豫不決，無法下決心的狀態。" },
      { "num": "2", "text": "美國亞利桑那州的著名自然地貌，由科羅拉多河切割而成。" },
      { "num": "3", "text": "成語，形容家境極其貧窮，像被水洗過一樣什麼都沒有。" },
      { "num": "4", "text": "一種常見的小吃湯品，通常以雞、鴨、豬的內臟為食材。" },
      { "num": "5", "text": "一種漸進性神經退化性疾病，常見症狀為短期記憶喪失。" },
      { "num": "6", "text": "台灣知名的食品公司，以蛋捲及休閒零嘴聞名。" },
      { "num": "7", "text": "台灣男配音員，代表作如《海綿寶寶》中的海綿寶寶。" },
      { "num": "8", "text": "一種常見料理，將雞蛋去殼後放入鍋中煎熟，並保持蛋黃完整。" },
      { "num": "9", "text": "建中學生的特殊自稱，因早期校內操場荒蕪一片，風吹過會有沙塵揚起，學生走在其中如駱駝。" },
      { "num": "10", "text": "位於台中市的一個行政區，境內有著名的靜宜大學及弘光科大。" }
